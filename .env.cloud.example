# Hosted Supabase project (copy to .env.cloud — gitignored)
# Use with: npm run dev:cloud (loads .env + .env.cloud, not .env.local)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon key from Supabase dashboard → Settings → API>

# Invite-only: provision users in Authentication → Users (no public signup).

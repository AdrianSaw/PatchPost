# Local Docker Supabase (copy to .env.local — gitignored)
# Start stack: npm run supabase:start
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=<Publishable key from npm run supabase:start — Authentication Keys>

# Vitest only — local Secret key from `npx supabase status` (invite-only: tests create users via Admin API)
SUPABASE_SERVICE_ROLE_KEY=<Secret key from npm run supabase:start — Authentication Keys>

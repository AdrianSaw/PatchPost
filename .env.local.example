# Local Docker Supabase (copy to .env.local — gitignored)
# Start stack: npx supabase start  (or npm run supabase:start after F-03 scripts land)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=<anon key from supabase start output>

# Optional generation keys may live in .env instead; Astro loads .env then .env.local in dev.

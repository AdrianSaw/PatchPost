---
import AppLayout from "@/layouts/AppLayout.astro";
import ProjectForm from "@/components/projects/ProjectForm";

const error = Astro.url.searchParams.get("error");
---

<AppLayout title="New project">
  <div class="mb-8 border-b border-white/10 pb-6">
    <a href="/app/projects" class="text-cosmic-muted text-sm transition-colors hover:text-purple-200 hover:underline">
      ← Back to projects
    </a>
    <h1 class="heading-gradient mt-3 text-2xl font-bold">New project</h1>
    <p class="text-cosmic-muted mt-2 max-w-lg text-sm leading-relaxed">
      Name your game or release line. You can add repo details and default tone now, or edit them later from the project
      hub.
    </p>
  </div>

  <ProjectForm action="/api/projects" errorMessage={error} client:load />
</AppLayout>

---
import AppLayout from "@/layouts/AppLayout.astro";
import { createClient } from "@/lib/supabase";
import { listProjects } from "@/lib/services/projects";
import type { Project } from "@/types";

const supabase = createClient(Astro.request.headers, Astro.cookies);

let projects: Project[] = [];
let configError: string | null = null;
let listError: string | null = null;

if (!supabase) {
  configError = "Supabase is not configured";
} else {
  const { data, error } = await listProjects(supabase);
  if (error) {
    listError = "Unable to load projects. Please try again.";
  } else {
    projects = data as Project[];
  }
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString(undefined, { dateStyle: "medium" });
}
---

<AppLayout title="Projects">
  <div class="mb-8 flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="heading-gradient text-2xl font-bold">Projects</h1>
      <p class="text-cosmic-muted mt-1 text-sm">
        Each project holds patch notes, generated drafts, and changelog history.
      </p>
    </div>
    {
      !configError && !listError && (
        <a href="/app/projects/new" class="btn-cosmic-primary shrink-0 px-4 py-2 text-sm">
          New project
        </a>
      )
    }
  </div>

  {
    configError && (
      <p class="rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">{configError}</p>
    )
  }

  {
    listError && (
      <p class="rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">{listError}</p>
    )
  }

  {
    !configError && !listError && projects.length === 0 && (
      <div class="glass-panel-sm mx-auto max-w-md px-6 py-10 text-center">
        <p class="text-lg font-medium text-white">No projects yet</p>
        <p class="text-cosmic-muted mt-2 text-sm leading-relaxed">
          Create a project for your game, then open it to generate player-facing changelog drafts from your patch notes.
        </p>
        <a href="/app/projects/new" class="btn-cosmic-primary mt-6 inline-flex px-5 py-2.5 text-sm">
          Create your first project
        </a>
      </div>
    )
  }

  {
    !configError && !listError && projects.length > 0 && (
      <ul class="space-y-2">
        {projects.map((project) => (
          <li>
            <a
              href={`/app/projects/${project.id}`}
              class="glass-panel-sm flex items-center justify-between gap-4 px-4 py-3 transition-colors hover:border-purple-400/20 hover:bg-white/10"
            >
              <span class="font-medium text-white">{project.name}</span>
              <span class="text-cosmic-subtle text-sm">Updated {formatDate(project.updated_at)}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</AppLayout>

---
import AppLayout from "@/layouts/AppLayout.astro";
import { createClient } from "@/lib/supabase";
import { listProjects } from "@/lib/services/projects";
import type { Project } from "@/types";

const supabase = createClient(Astro.request.headers, Astro.cookies);

let projects: Project[] = [];
let configError: string | null = null;
let listError: string | null = null;

if (!supabase) {
  configError = "Supabase is not configured";
} else {
  const { data, error } = await listProjects(supabase);
  if (error) {
    listError = "Unable to load projects. Please try again.";
  } else {
    projects = data as Project[];
  }
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString(undefined, { dateStyle: "medium" });
}
---

<AppLayout title="Projects">
  <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
    <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
      Projects
    </h1>
    {
      !configError && !listError && (
        <a
          href="/app/projects/new"
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
        >
          New project
        </a>
      )
    }
  </div>

  {
    configError && (
      <p class="rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">{configError}</p>
    )
  }

  {
    listError && (
      <p class="rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">{listError}</p>
    )
  }

  {
    !configError && !listError && projects.length === 0 && (
      <div class="text-center">
        <p class="text-blue-100/80">No projects yet.</p>
        <a
          href="/app/projects/new"
          class="mt-4 inline-block rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
        >
          Create your first project
        </a>
      </div>
    )
  }

  {
    !configError && !listError && projects.length > 0 && (
      <ul class="divide-y divide-white/10">
        {projects.map((project) => (
          <li>
            <a
              href={`/app/projects/${project.id}`}
              class="flex items-center justify-between gap-4 py-4 transition-colors hover:bg-white/5"
            >
              <span class="font-medium text-white">{project.name}</span>
              <span class="text-sm text-blue-100/50">Updated {formatDate(project.updated_at)}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</AppLayout>

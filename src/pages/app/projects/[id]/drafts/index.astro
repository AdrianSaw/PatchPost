---
import AppLayout from "@/layouts/AppLayout.astro";
import { formatOutputType, formatTone } from "@/lib/generation/labels";
import { draftDisplayTitle, draftSnippet } from "@/lib/projects/draft-text";
import { formatProjectDate } from "@/lib/projects/project-detail-page";
import { loadDraftsPage } from "@/lib/projects/drafts-page";

const page = await loadDraftsPage(Astro);

if (page.kind === "redirect") {
  return Astro.redirect(page.to);
}

const { project, drafts, showSuccessBanner, showSavedBanner, showRevertedBanner, listError, listTruncated } = page;
---

<AppLayout title={`Drafts — ${project.name}`} projectId={project.id} projectName={project.name} activeTab="drafts">
  <div class="mb-6 flex flex-wrap items-start justify-between gap-4">
    <div>
      <p class="text-cosmic-subtle mb-2 text-xs font-medium tracking-wide uppercase">Step 3 of 3 · Review</p>
      <h1 class="heading-gradient text-2xl font-bold">Draft history</h1>
      <p class="text-cosmic-muted mt-1 text-sm">Saved generated content for this project.</p>
    </div>
    <a href={`/app/projects/${project.id}/generate`} class="btn-cosmic-primary shrink-0 px-4 py-2 text-sm">
      Generate new
    </a>
  </div>

  {
    showRevertedBanner && (
      <p
        class="mb-6 rounded-lg border border-green-500/40 bg-green-950/40 px-4 py-3 text-sm font-medium text-green-200"
        role="status"
      >
        Draft reverted to original.
      </p>
    )
  }

  {
    showSavedBanner && (
      <p
        class="mb-6 rounded-lg border border-green-500/40 bg-green-950/40 px-4 py-3 text-sm font-medium text-green-200"
        role="status"
      >
        Draft changes saved.
      </p>
    )
  }

  {
    showSuccessBanner && (
      <p
        class="mb-6 rounded-lg border border-green-500/40 bg-green-950/40 px-4 py-3 text-sm font-medium text-green-200"
        role="status"
      >
        Draft saved to history.
      </p>
    )
  }

  {
    listError && (
      <p class="mb-6 rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">{listError}</p>
    )
  }

  {
    !listError && drafts.length === 0 && (
      <div class="glass-panel-sm mx-auto max-w-md px-6 py-10 text-center">
        <p class="text-lg font-medium text-white">No drafts yet</p>
        <p class="text-cosmic-muted mt-2 text-sm">
          Generate your first draft from patch notes, then it will appear here.
        </p>
        <a
          href={`/app/projects/${project.id}/generate`}
          class="btn-cosmic-primary mt-6 inline-flex px-5 py-2.5 text-sm"
        >
          Generate your first draft
        </a>
      </div>
    )
  }

  {
    !listError && drafts.length > 0 && (
      <>
        {listTruncated && <p class="text-cosmic-subtle mb-4 text-sm">Showing the 50 most recent drafts.</p>}
        <ul class="space-y-2">
          {drafts.map(({ draft, output_type, tone }) => (
            <li>
              <a
                href={`/app/projects/${project.id}/drafts/${draft.id}`}
                class="glass-panel-sm block px-4 py-3 transition-colors hover:border-purple-400/20 hover:bg-white/10"
              >
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-2">
                      <p class="font-medium text-white">{draftDisplayTitle(draft)}</p>
                      {draft.edited_content != null ? (
                        <span class="rounded border border-purple-400/30 bg-purple-900/30 px-2 py-0.5 text-xs text-purple-200">
                          Edited
                        </span>
                      ) : null}
                    </div>
                    <p class="text-cosmic-muted mt-1 text-sm">{draftSnippet(draft)}</p>
                  </div>
                  <div class="text-cosmic-subtle text-right text-sm">
                    <p class="font-medium text-white/80">{formatOutputType(output_type)}</p>
                    {tone ? <p class="mt-1">{formatTone(tone)}</p> : null}
                    <p class="mt-1">{formatProjectDate(draft.created_at)}</p>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </>
    )
  }
</AppLayout>

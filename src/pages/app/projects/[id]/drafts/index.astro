---
import AppLayout from "@/layouts/AppLayout.astro";
import { formatOutputType, formatTone } from "@/lib/generation/labels";
import { draftDisplayTitle, draftSnippet } from "@/lib/projects/draft-text";
import { formatProjectDate } from "@/lib/projects/project-detail-page";
import { loadDraftsPage } from "@/lib/projects/drafts-page";

const page = await loadDraftsPage(Astro);

if (page.kind === "redirect") {
  return Astro.redirect(page.to);
}

const { project, drafts, showSuccessBanner, showSavedBanner, showRevertedBanner, listError, listTruncated } = page;
---

<AppLayout title={`Drafts — ${project.name}`}>
  <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
    <div class="mb-6">
      <a
        href={`/app/projects/${project.id}`}
        class="text-sm text-purple-300 transition-colors hover:text-purple-100 hover:underline"
      >
        ← Back to {project.name}
      </a>
      <div class="mt-4 flex flex-wrap items-center justify-between gap-4">
        <div>
          <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
            Draft history
          </h1>
          <p class="mt-1 text-sm text-blue-100/50">Saved generated content for this project.</p>
        </div>
        <a
          href={`/app/projects/${project.id}/generate`}
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
        >
          Generate new
        </a>
      </div>
    </div>

    {
      showRevertedBanner && (
        <p class="mb-6 rounded-lg border border-green-500/30 bg-green-900/20 px-3 py-2 text-sm text-green-200">
          Draft reverted to original.
        </p>
      )
    }

    {
      showSavedBanner && (
        <p class="mb-6 rounded-lg border border-green-500/30 bg-green-900/20 px-3 py-2 text-sm text-green-200">
          Draft changes saved.
        </p>
      )
    }

    {
      showSuccessBanner && (
        <p class="mb-6 rounded-lg border border-green-500/30 bg-green-900/20 px-3 py-2 text-sm text-green-200">
          Draft saved to history.
        </p>
      )
    }

    {
      listError && (
        <p class="mb-6 rounded-lg border border-red-500/30 bg-red-900/30 px-3 py-2 text-sm text-red-300">{listError}</p>
      )
    }

    {
      !listError && drafts.length === 0 && (
        <div class="text-center">
          <p class="text-blue-100/80">No drafts yet.</p>
          <a
            href={`/app/projects/${project.id}/generate`}
            class="mt-4 inline-block rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
          >
            Generate your first draft
          </a>
        </div>
      )
    }

    {
      !listError && drafts.length > 0 && (
        <>
          {listTruncated && <p class="mb-4 text-sm text-blue-100/50">Showing the 50 most recent drafts.</p>}
          <ul class="divide-y divide-white/10">
            {drafts.map(({ draft, output_type, tone }) => (
              <li>
                <a
                  href={`/app/projects/${project.id}/drafts/${draft.id}`}
                  class="block py-4 transition-colors hover:bg-white/5"
                >
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex flex-wrap items-center gap-2">
                        <p class="font-medium text-white">{draftDisplayTitle(draft)}</p>
                        {draft.edited_content != null ? (
                          <span class="rounded border border-purple-400/30 bg-purple-900/30 px-2 py-0.5 text-xs text-purple-200">
                            Edited
                          </span>
                        ) : null}
                      </div>
                      <p class="mt-1 text-sm text-blue-100/70">{draftSnippet(draft)}</p>
                    </div>
                    <div class="text-right text-sm text-blue-100/50">
                      <p>{formatOutputType(output_type)}</p>
                      {tone ? <p class="mt-1">{formatTone(tone)}</p> : null}
                      <p class="mt-1">{formatProjectDate(draft.created_at)}</p>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </>
      )
    }
  </div>
</AppLayout>

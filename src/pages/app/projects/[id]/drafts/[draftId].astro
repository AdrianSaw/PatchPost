---
import AppLayout from "@/layouts/AppLayout.astro";
import ClassificationPanel from "@/components/generation/ClassificationPanel";
import DraftEditForm from "@/components/generation/DraftEditForm";
import { formatOutputType, formatTone } from "@/lib/generation/labels";
import { draftBody, draftDisplayTitle } from "@/lib/projects/draft-text";
import { loadDraftDetailPage } from "@/lib/projects/draft-detail-page";
import { formatProjectDate } from "@/lib/projects/project-detail-page";

const page = await loadDraftDetailPage(Astro);

if (page.kind === "redirect") {
  return Astro.redirect(page.to);
}

const { project, draft, generationRun, classifiedItems, outputLanguage } = page;
const body = draftBody(draft);
---

<AppLayout
  title={`${draftDisplayTitle(draft)} — ${project.name}`}
  projectId={project.id}
  projectName={project.name}
  activeTab="drafts"
>
  <div class="mb-8">
    <h1 class="heading-gradient text-2xl font-bold">
      {draftDisplayTitle(draft)}
    </h1>
    <p class="text-cosmic-subtle mt-2 text-sm">
      {formatOutputType(generationRun?.output_type)}
      {generationRun?.tone ? ` · ${formatTone(generationRun.tone)}` : ""}
      · Created {formatProjectDate(draft.created_at)}
    </p>
    <p class="text-cosmic-muted mt-2 text-sm">Edit the generated copy before you ship it to players.</p>
  </div>

  {
    classifiedItems.length > 0 && (
      <div class="mb-6">
        <ClassificationPanel items={classifiedItems} outputLanguage={outputLanguage} client:load />
      </div>
    )
  }

  <div class="glass-panel-sm p-4 sm:p-6">
    <DraftEditForm
      projectId={project.id}
      draftId={draft.id}
      initialBody={body}
      showRevert={draft.edited_content != null}
      client:load
    />
  </div>
</AppLayout>

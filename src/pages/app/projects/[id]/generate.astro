---
import AppLayout from "@/layouts/AppLayout.astro";
import GenerateForm from "@/components/generation/GenerateForm";
import { formatProjectDate } from "@/lib/projects/project-detail-page";
import { loadGeneratePage } from "@/lib/projects/generate-page";

const page = await loadGeneratePage(Astro);

if (page.kind === "redirect") {
  return Astro.redirect(page.to);
}

const { project, error } = page;
---

<AppLayout title={`Generate — ${project.name}`}>
  <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
    <div class="mb-6">
      <a
        href={`/app/projects/${project.id}`}
        class="text-sm text-purple-300 transition-colors hover:text-purple-100 hover:underline"
      >
        ← Back to {project.name}
      </a>
      <h1 class="mt-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
        Generate content
      </h1>
      <p class="mt-1 text-sm text-blue-100/50">
        Paste your changes, pick a channel, and generate player-facing copy for {project.name}.
      </p>
      <p class="mt-1 text-xs text-blue-100/40">
        Updated {formatProjectDate(project.updated_at)}
      </p>
    </div>

    <GenerateForm
      projectId={project.id}
      defaultTone={project.default_tone}
      initialError={error}
      showDevMockToggle={import.meta.env.DEV}
      client:load
    />
  </div>
</AppLayout>

---
import AppLayout from "@/layouts/AppLayout.astro";
import GenerateForm from "@/components/generation/GenerateForm";
import { loadGeneratePage } from "@/lib/projects/generate-page";

const page = await loadGeneratePage(Astro);

if (page.kind === "redirect") {
  return Astro.redirect(page.to);
}

const { project, error } = page;
---

<AppLayout title={`Generate — ${project.name}`} projectId={project.id} projectName={project.name} activeTab="generate">
  <div class="mb-8">
    <h1 class="heading-gradient text-2xl font-bold">Generate content</h1>
    <p class="text-cosmic-muted mt-2 text-sm leading-relaxed">
      Paste your changes, pick a channel, and generate player-facing copy for {project.name}.
    </p>
  </div>

  <GenerateForm
    projectId={project.id}
    defaultTone={project.default_tone}
    initialError={error}
    showDevMockToggle={import.meta.env.DEV}
    client:load
  />
</AppLayout>

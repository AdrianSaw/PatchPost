---
import AppLayout from "@/layouts/AppLayout.astro";
import DeleteProjectForm from "@/components/projects/DeleteProjectForm";
import ProjectForm from "@/components/projects/ProjectForm";
import { formatProjectDate, loadProjectDetailPage } from "@/lib/projects/project-detail-page";

const page = await loadProjectDetailPage(Astro);

if (page.kind === "redirect") {
  return Astro.redirect(page.to);
}

const { project, error } = page;
const apiAction = `/api/projects/${project.id}`;
---

<AppLayout title={project.name}>
  <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
    <div class="mb-6">
      <a href="/app/projects" class="text-sm text-purple-300 transition-colors hover:text-purple-100 hover:underline">
        ← Back to projects
      </a>
      <h1 class="mt-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
        {project.name}
      </h1>
      <p class="mt-1 text-sm text-blue-100/50">
        Created {formatProjectDate(project.created_at)} · Updated {formatProjectDate(project.updated_at)}
      </p>
    </div>

    <ProjectForm
      action={apiAction}
      defaultValues={{
        name: project.name,
        description: project.description,
        repo_url: project.repo_url,
        default_tone: project.default_tone,
      }}
      hiddenFields={{ _action: "update" }}
      errorMessage={error}
      submitLabel="Save changes"
      pendingText="Saving..."
      client:load
    />

    <div class="mt-10 border-t border-white/10 pt-8">
      <h2 class="mb-4 text-lg font-semibold text-red-300">Danger zone</h2>
      <DeleteProjectForm action={apiAction} client:load />
    </div>
  </div>
</AppLayout>

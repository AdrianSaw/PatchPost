---
import AppLayout from "@/layouts/AppLayout.astro";
import { createClient } from "@/lib/supabase";
import { draftDisplayTitle, draftSnippet } from "@/lib/projects/draft-text";
import { formatProjectDate, loadProjectDetailPage } from "@/lib/projects/project-detail-page";
import { getLatestProjectDraft } from "@/lib/services/generated-outputs";

const page = await loadProjectDetailPage(Astro);

if (page.kind === "redirect") {
  return Astro.redirect(page.to);
}

const { project } = page;

const supabase = createClient(Astro.request.headers, Astro.cookies);
let recentDraft = null;
let recentDraftError: string | null = null;
if (supabase) {
  const { data, error } = await getLatestProjectDraft(supabase, project.id);
  if (error) {
    recentDraftError = "Unable to load latest draft.";
  } else {
    recentDraft = data;
  }
}
---

<AppLayout title={project.name} projectId={project.id} projectName={project.name} activeTab="overview">
  <div class="mb-8">
    <h1 class="heading-gradient text-2xl font-bold">{project.name}</h1>
    <p class="text-cosmic-subtle mt-1 text-sm">
      Created {formatProjectDate(project.created_at)} · Updated {formatProjectDate(project.updated_at)}
    </p>
    <p class="text-cosmic-muted mt-3 max-w-xl text-sm leading-relaxed">
      Turn patch notes into player-facing copy. Generate a new draft, then review it in draft history.
    </p>
  </div>

  <div class="mb-8 grid gap-4 sm:grid-cols-2">
    <div class="glass-panel-sm p-5">
      <p class="font-semibold text-white">Generate</p>
      <p class="text-cosmic-muted mt-1 text-sm">Paste changes and create a new changelog or social draft.</p>
      <a href={`/app/projects/${project.id}/generate`} class="btn-cosmic-primary mt-4 inline-flex px-4 py-2 text-sm">
        Open generate
      </a>
    </div>
    <div class="glass-panel-sm p-5">
      <p class="font-semibold text-white">Draft history</p>
      <p class="text-cosmic-muted mt-1 text-sm">Browse saved outputs and edit text before you ship.</p>
      <a
        href={`/app/projects/${project.id}/drafts`}
        class="mt-4 inline-flex rounded-lg border border-white/20 bg-white/5 px-4 py-2 text-sm text-white transition-colors hover:bg-white/10"
      >
        View drafts
      </a>
    </div>
  </div>

  {recentDraftError && <p class="text-cosmic-subtle mb-4 text-sm">{recentDraftError}</p>}

  {
    recentDraft && (
      <div class="glass-panel-sm p-5">
        <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
          <h2 class="text-sm font-semibold text-white">Latest draft</h2>
          <a
            href={`/app/projects/${project.id}/drafts/${recentDraft.draft.id}`}
            class="text-sm text-purple-300 hover:text-purple-100 hover:underline"
          >
            Open
          </a>
        </div>
        <p class="font-medium text-white">{draftDisplayTitle(recentDraft.draft)}</p>
        <p class="text-cosmic-muted mt-1 text-sm">{draftSnippet(recentDraft.draft)}</p>
      </div>
    )
  }
</AppLayout>

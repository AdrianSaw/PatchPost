---
interface Props {
  title: string;
  description: string;
  class?: string;
}

const { title, description, class: className = "" } = Astro.props;
---

<div class:list={["glass-panel-sm p-6", className]}>
  <div class="mb-4 text-purple-300">
    <slot name="icon" />
  </div>
  <h3 class="mb-2 text-lg font-semibold text-white">{title}</h3>
  <p class="text-cosmic-muted text-sm leading-relaxed">{description}</p>
</div>

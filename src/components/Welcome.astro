---
import CosmicShell from "@/components/layout/CosmicShell.astro";
import BrandTopbar from "@/components/layout/BrandTopbar.astro";
import FeatureCard from "@/components/layout/FeatureCard.astro";

const { user } = Astro.locals;
---

<CosmicShell variant="auth-wide">
  <BrandTopbar homeHref="/">
    {
      user ? (
        <div slot="actions" class="flex items-center gap-3">
          <span class="text-cosmic-muted hidden max-w-[12rem] truncate sm:inline">{user.email}</span>
          <a href="/app/projects" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Projects
          </a>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
              Sign out
            </button>
          </form>
        </div>
      ) : (
        <a
          slot="actions"
          href="/auth/signin"
          class="text-purple-300 transition-colors hover:text-purple-100 hover:underline"
        >
          Sign in
        </a>
      )
    }
  </BrandTopbar>

  <div class="mx-auto flex max-w-4xl flex-col items-center justify-center px-4 py-20 text-center sm:py-28 lg:py-36">
    <h1 class="heading-gradient mb-6 text-5xl leading-tight font-bold sm:text-6xl lg:text-7xl">PatchPost</h1>
    <p class="text-cosmic-subtle mb-10 max-w-2xl text-lg sm:text-xl">
      Turn game-repo changes into player-facing changelogs and social-ready copy — without losing your patch notes along
      the way.
    </p>
    <div class="flex flex-col gap-4 sm:flex-row">
      <a href="/auth/signin" class="btn-cosmic-primary px-6 py-3 text-base">Sign in</a>
    </div>
  </div>

  <div class="mx-auto grid max-w-4xl grid-cols-1 gap-6 px-4 pb-24 sm:grid-cols-3">
    <FeatureCard
      title="Projects & Drafts"
      description="Organize updates by game project and keep every changelog draft in one workspace."
    >
      <svg
        slot="icon"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"
        ></path>
        <path d="M8 10v4"></path>
        <path d="M12 10v2"></path>
        <path d="M16 10v6"></path>
      </svg>
    </FeatureCard>

    <FeatureCard
      title="AI Draft Generation"
      description="Paste patch notes and generate player-friendly copy tuned to your channel and tone."
    >
      <svg
        slot="icon"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"
        ></path>
        <path d="M20 3v4"></path>
        <path d="M22 5h-4"></path>
        <path d="M4 17v2"></path>
        <path d="M5 18H3"></path>
      </svg>
    </FeatureCard>

    <FeatureCard
      title="Invite-only workspace"
      description="Access is by invitation — your team signs in and picks up where the last draft left off."
    >
      <svg
        slot="icon"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>
    </FeatureCard>
  </div>
</CosmicShell>

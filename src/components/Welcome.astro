---
import CosmicShell from "@/components/layout/CosmicShell.astro";
import BrandTopbar from "@/components/layout/BrandTopbar.astro";
import FeatureCard from "@/components/layout/FeatureCard.astro";

const { user } = Astro.locals;
---

<CosmicShell variant="auth-wide">
  <BrandTopbar homeHref="/">
    {
      user ? (
        <div slot="actions" class="flex items-center gap-3">
          <span class="text-cosmic-muted hidden max-w-[12rem] truncate sm:inline">{user.email}</span>
          <a href="/app/projects" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Projects
          </a>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
              Sign out
            </button>
          </form>
        </div>
      ) : (
        <a
          slot="actions"
          href="/auth/signin"
          class="text-purple-300 transition-colors hover:text-purple-100 hover:underline"
        >
          Sign in
        </a>
      )
    }
  </BrandTopbar>

  <div class="mx-auto flex max-w-4xl flex-col items-center justify-center px-4 py-24 text-center sm:py-32 lg:py-40">
    <h1
      class="mb-6 bg-gradient-to-r from-blue-200 via-purple-200 to-pink-200 bg-clip-text text-5xl leading-tight font-bold text-transparent sm:text-6xl lg:text-7xl"
    >
      10x Astro Starter
    </h1>
    <p class="text-cosmic-subtle mb-10 max-w-2xl text-lg sm:text-xl">
      A production-ready starter with authentication, modern tooling, and a cosmic developer experience.
    </p>
    <div class="flex flex-col gap-4 sm:flex-row">
      <a href="/auth/signin" class="btn-cosmic-primary px-6 py-3 text-base"> Sign In </a>
    </div>
  </div>

  <div class="mx-auto grid max-w-4xl grid-cols-1 gap-6 px-4 pb-24 sm:grid-cols-3">
    <FeatureCard
      title="Authentication Ready"
      description="Invite-only Supabase sign-in with protected routes — no public registration."
    >
      <svg
        slot="icon"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>
    </FeatureCard>

    <FeatureCard
      title="Modern Stack"
      description="Astro 5, React 19, Tailwind 4, and TypeScript — the latest tools, ready to go."
    >
      <svg
        slot="icon"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
        <polyline points="2 17 12 22 22 17"></polyline>
        <polyline points="2 12 12 17 22 12"></polyline>
      </svg>
    </FeatureCard>

    <FeatureCard
      title="Developer Experience"
      description="ESLint, Prettier, and pre-commit hooks keep your codebase clean from day one."
    >
      <svg
        slot="icon"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="16 18 22 12 16 6"></polyline>
        <polyline points="8 6 2 12 8 18"></polyline>
      </svg>
    </FeatureCard>
  </div>
</CosmicShell>
